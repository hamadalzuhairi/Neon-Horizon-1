{
  "collections": [
    {
      "name": "users",
      "fields": [
        { "name": "username", "type": "string", "required": true },
        { "name": "uid", "type": "string", "required": true },
        { "name": "createdAt", "type": "timestamp", "required": true }
      ],
      "rules": [
        { "action": "read", "allow": "true" },
        { "action": "create", "allow": "request.auth != null && request.auth.uid == request.resource.data.uid && !exists(/databases/$(database)/documents/usernames/$(request.resource.data.username))" },
        { "action": "update", "allow": "false" },
        { "action": "delete", "allow": "false" }
      ]
    },
    {
      "name": "usernames",
      "fields": [
        { "name": "uid", "type": "string", "required": true }
      ],
      "rules": [
        { "action": "read", "allow": "true" },
        { "action": "create", "allow": "request.auth != null && request.auth.uid == request.resource.data.uid && request.resource.id != ''" },
        { "action": "update", "allow": "false" },
        { "action": "delete", "allow": "false" }
      ]
    },
    {
      "name": "leaderboard",
      "fields": [
        { "name": "username", "type": "string", "required": true },
        { "name": "score", "type": "number", "required": true },
        { "name": "uid", "type": "string", "required": true },
        { "name": "timestamp", "type": "timestamp", "required": true }
      ],
      "rules": [
        { "action": "read", "allow": "true" },
        { "action": "create", "allow": "request.auth != null && request.auth.uid == request.resource.data.uid" },
        { "action": "update", "allow": "request.auth != null && request.auth.uid == request.resource.data.uid && request.resource.data.score > resource.data.score" },
        { "action": "delete", "allow": "false" }
      ]
    }
  ]
}
